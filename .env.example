# Inventory Sync v0.1 — config template. Copy to .env and fill in.
# Never put real secrets in this file.

# --- Shopify ---
SHOPIFY_STORE_URL=https://your-store.myshopify.com/
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_MYSHOPIFY_DOMAIN=xxx.myshopify.com
SHOPIFY_API_VERSION=2024-10

# --- Vendor ---
VENDOR_NAME=
VENDOR_URL=
VENDOR_USERNAME=
VENDOR_PASSWORD=
VENDOR_STORE_TAG=

# --- WhatsApp notifications (via the Go bridge) ---
WHATSAPP_API_BASE_URL=http://localhost:8080/api
WHATSAPP_API_TOKEN=
# Dev/ops recipient: infrastructure + sync-error alerts.
WHATSAPP_OPS_NUMBER=
# Store-owner recipient: business alerts (OOS summaries, digests).
WHATSAPP_CLIENT_NUMBER=

# --- Email notifications (pluggable provider) ---
EMAIL_PROVIDER=resend
EMAIL_API_BASE_URL=https://api.resend.com
EMAIL_API_KEY=
EMAIL_FROM=
EMAIL_OPS_ADDRESS=
EMAIL_CLIENT_ADDRESS=

# --- Notifications ---
# Two categories; flip each whole category on/off:
NOTIFY_OPS_ENABLED=true
NOTIFY_CLIENT_ENABLED=true
NOTIFY_WHATSAPP_ENABLED=true
NOTIFY_EMAIL_ENABLED=true
# Per-event routing — _TO (ops|client|both|none) + _VIA (whatsapp|email|both|none)
NOTIFY_SYNC_ERROR_TO=ops
NOTIFY_SYNC_ERROR_VIA=whatsapp
NOTIFY_SYNC_SUMMARY_TO=ops
NOTIFY_SYNC_SUMMARY_VIA=whatsapp
NOTIFY_ARCHIVE_AUDIT_TO=client
NOTIFY_ARCHIVE_AUDIT_VIA=whatsapp

# --- Axiom log sink (used by the future LogSink adapter; ingest-scoped token) ---
AXIOM_API_URL=https://api.axiom.co
AXIOM_API_TOKEN=xaat-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AXIOM_DATASET=inventory-sync

# --- Sync engine ---
SYNC_INTERVAL=hourly

# --- Persistence (sqlite for dev, postgres URL for prod) ---
DATABASE_URL=sqlite:///inventory_sync.db
